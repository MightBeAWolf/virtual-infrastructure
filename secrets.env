#!/bin/bash
 
# NOTE, these are just 1password secret references. No secrets or credentials
# should be explicitly stored anywhere in this project, including this file!
ONEPASSWORD_VAULT="Private"
PROXMOX_API_ITEM="Proxmox Ansible API Token"

export PROXMOX_API_TOKEN_ID="op://${ONEPASSWORD_VAULT:?}/${PROXMOX_API_ITEM:?}/username"
export PROXMOX_API_SECRET="op://${ONEPASSWORD_VAULT:?}/${PROXMOX_API_ITEM:?}/credential"
export PROXMOX_API_HOSTNAME="op://${ONEPASSWORD_VAULT:?}/${PROXMOX_API_ITEM:?}/hostname"

export PROXMOX_VM_TEMPLATE_USER="op://Local Cluster/Local Cluster Template User/username"
export PROXMOX_VM_TEMPLATE_PASSWD="op://Local Cluster/Local Cluster Template User/password"
